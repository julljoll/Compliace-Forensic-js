# SHA256.US — Variables de Entorno
# Copiar este archivo como .env y completar los valores

# Base de datos Neon PostgreSQL (opcional)
# Obtener URL en: https://console.neon.tech
VITE_DATABASE_URL=postgresql://usuario:password@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require

# Vercel OAuth (para inicio de sesión con Vercel)
# 1. Crear OAuth App en: https://vercel.com/dashboard/account/integrations
# 2. Configurar Redirect URI apuntando a: https://tu-dominio.com/auth/vercel-callback
# 3. Copiar Client ID y Client Secret aquí
VERCEL_OAUTH_CLIENT_ID=
VERCEL_OAUTH_CLIENT_SECRET=
VERCEL_OAUTH_REDIRECT_URI=

# URL base de la API (para el callback de OAuth)
# En desarrollo: http://localhost:3000/api/oauth/vercel
# En producción: /api/oauth/vercel (o URL completa de la función serverless)
VITE_API_URL=
