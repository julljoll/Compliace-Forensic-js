{
  "name": "sha256-peritaje-whatsapp",
  "version": "1.0.0",
  "description": "SHA256.US — Sistema de Peritaje Digital WhatsApp · Contratos Digitales · Civil/Mercantil",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "tsc && vite build && electron-builder",
    "electron:build:deb": "tsc && vite build && electron-builder --linux deb",
    "electron:build:win": "tsc && vite build && electron-builder --win nsis",
    "electron:build:all": "tsc && vite build && electron-builder --linux deb --win nsis"
  },
  "keywords": [
    "peritaje",
    "whatsapp",
    "forense",
    "contratos-digitales",
    "firmas-electronicas",
    "civil-mercantil"
  ],
  "author": "Perito Privado Digital",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.15.2",
    "better-sqlite3": "^12.10.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "workbox-window": "^7.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.5.12",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-pwa": "^1.2.0",
    "wait-on": "^9.0.5"
  },
  "overrides": {
    "vite-plugin-pwa": {
      "vite": "$vite"
    }
  },
  "build": {
    "appId": "com.sha256.peritaje",
    "productName": "SHA256 Peritaje WhatsApp",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*",
      "node_modules/prebuild-install/**/*"
    ],
    "extraResources": [
      "public/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "linux": {
      "target": [
        "deb"
      ],
      "category": "Utility",
      "maintainer": "Perito Digital <admin@sha256.us>",
      "icon": "public/icon.png",
      "desktop": {
        "entry": {
          "Name": "SHA256 Peritaje WhatsApp",
          "Comment": "Sistema de Peritaje Digital para Contratos WhatsApp",
          "Categories": "Utility;System;"
        }
      }
    },
    "deb": {
      "depends": [],
      "priority": "optional"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/icon.icns",
      "category": "public.app-category.utilities"
    }
  }
}
