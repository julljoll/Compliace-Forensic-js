{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/mimo-v2.5-free",
  "instructions": [
    "AGENTS.md",
    "docs/design_tokens.md",
    "docs/map_arquitectura.md"
  ],
  "agent": {
    "build": {
      "mode": "primary",
      "model": "opencode/mimo-v2.5-free",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "skill": "allow"
      }
    },
    "plan": {
      "mode": "primary",
      "model": "opencode/mimo-v2.5-free",
      "permission": {
        "edit": "ask",
        "bash": "ask",
        "skill": "allow"
      }
    },
    "compliance-officer": {
      "description": "Compliance Officer Legal-Jurídico-Forense-Digital. Gestionar cumplimiento normativo, cadena de custodia, auditoría y planillas oficiales.",
      "mode": "subagent",
      "model": "opencode/mimo-v2.5-free",
      "prompt": "{file:.opencode/agents/compliance-officer.md}",
      "permission": {
        "skill": "allow",
        "read": "allow"
      }
    },
    "perito-forense": {
      "description": "Perito Informático Forense Digital. Análisis de evidencia, herramientas forenses, hash verification y dictamen pericial.",
      "mode": "subagent",
      "model": "opencode/mimo-v2.5-free",
      "prompt": "{file:.opencode/agents/perito-forense.md}",
      "permission": {
        "skill": "allow",
        "read": "allow"
      }
    },
    "legal-analyst": {
      "description": "Analista Legal Venezolano. Fundamentación jurídica, marco legal, normativas ISO y estándares internacionales.",
      "mode": "subagent",
      "model": "opencode/mimo-v2.5-free",
      "prompt": "{file:.opencode/agents/legal-analyst.md}",
      "permission": {
        "skill": "allow",
        "read": "allow"
      }
    }
  },
  "permission": {
    "skill": {
      "*": "allow"
    }
  },
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".next/**", "dev-dist/**"]
  }
}
